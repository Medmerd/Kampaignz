{
  "name": "kampaignz",
  "productName": "kampaignz",
  "version": "1.0.0",
  "description": "Table Top Campaign Builder/Manager",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "VITE_DB_CLIENT=devpostgresql vite --config vite.renderer.config.ts",
    "start:web": "tsx src/main/web-server.ts",
    "dev:web": "tsx watch src/main/web-server.ts"
  },
  "keywords": [],
  "author": "Edward Lawrence",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitest/coverage-v8": "^2.1.9",
    "electron": "41.5.0",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "sqlite3": "^6.0.1",
    "tsx": "^4.22.3",
    "typescript": "~4.5.4",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "antd": "^6.3.7",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "electron-squirrel-startup": "^1.0.1",
    "express": "^5.2.1",
    "knex": "^3.2.10",
    "konva": "^10.3.0",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "react-konva": "^19.2.4",
    "uuid": "^14.0.0"
  }
}
